{
  "expo": {
    "name": "Moodle Client",
    "slug": "moodle-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "moodle-client",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0a09"
    },
    "ios": {
      "bundleIdentifier": "com.dotnaos.moodleclient",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "The app needs camera access to scan Moodle and OAuth pairing QR codes."
      }
    },
    "android": {
      "package": "com.dotnaos.moodleclient",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c0a09"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "db508694-d456-463c-9a25-2d9e3620c052"
      }
    },
    "owner": "omiq"
  }
}
