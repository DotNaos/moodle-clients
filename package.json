{
  "name": "moodle-clients",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "proxy:dev": "node ./scripts/moodle-proxy-dev.cjs",
    "web:dev": "bun run --filter @moodle-clients/web dev",
    "web:dev:portless": "portless moodle sh -lc 'unset CLERK_SECRET_KEY CLERK_PUBLISHABLE_KEY; cd apps/web && bun next dev --hostname 0.0.0.0 --port \"$PORT\"'",
    "services:dev:docker": "bash ./scripts/start-local-moodle-services.sh",
    "services:dev:docker:stop": "bash ./scripts/stop-local-moodle-services.sh",
    "web:dev:expo": "bun run --filter @moodle-clients/web dev:expo",
    "web:build": "bun run --filter @moodle-clients/web build",
    "study:import": "bun ./scripts/import-study-bundle.mjs",
    "mobile:dev": "node ./scripts/mobile-with-proxy-dev.cjs start",
    "mobile:start": "node ./scripts/mobile-with-proxy-dev.cjs start",
    "mobile:ios": "node ./scripts/mobile-with-proxy-dev.cjs ios",
    "mobile:android": "node ./scripts/mobile-with-proxy-dev.cjs android",
    "mobile:sentry:smoke": "node ./scripts/sentry-mobile-smoke-test.mjs",
    "moodle:fetch-login": "bun ./scripts/fhgr-fetch-login.mjs",
    "webex:fetch-poc": "bun ./scripts/webex-fetch-poc.mjs",
    "extension:dev": "bun run --filter @moodle-clients/extension dev",
    "extension:build": "bun run --filter @moodle-clients/extension build"
  },
  "devDependencies": {
    "eas-cli": "^18.8.1",
    "eslint": "^9.39.1",
    "turbo": "^2.6.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0"
  },
  "dependencies": {
    "@openai/codex-sdk": "0.125.0",
    "@react-native-cookies/cookies": "^6.2.1"
  },
  "trustedDependencies": [
    "@clerk/shared"
  ]
}
