{
  "name": "moodle-clients",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "proxy:dev": "node ./scripts/moodle-proxy-dev.cjs",
    "web:dev": "bun run --filter @moodle-clients/web dev",
    "web:dev:expo": "bun run --filter @moodle-clients/web dev:expo",
    "web:build": "bun run --filter @moodle-clients/web build",
    "mobile:dev": "bun run --filter @moodle-clients/mobile start",
    "mobile:start": "bun run --filter @moodle-clients/mobile start",
    "mobile:ios": "bun run --filter @moodle-clients/mobile ios",
    "mobile:android": "bun run --filter @moodle-clients/mobile android",
    "extension:dev": "bun run --filter @moodle-clients/extension dev",
    "extension:build": "bun run --filter @moodle-clients/extension build"
  },
  "devDependencies": {
    "eas-cli": "^18.8.1",
    "turbo": "^2.6.1",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@openai/codex-sdk": "0.125.0",
    "@vercel/sandbox": "^1.10.0"
  },
  "trustedDependencies": [
    "@clerk/shared"
  ]
}
